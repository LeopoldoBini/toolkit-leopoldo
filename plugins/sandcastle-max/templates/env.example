# Claude Code OAuth token (preferred — uses your Claude Max subscription).
# Generate with: claude setup-token
#
# On macOS, /sandcastle-build and /sandcastle-run read this from the Keychain
# automatically — you only need to set CLAUDE_CODE_OAUTH_TOKEN here on Linux
# or as an override.
#
# See: https://docs.claude.com/en/docs/claude-code/setup
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub personal access token (scopes: repo, read:org).
# Used by the agent inside the container to comment issues and open PRs.
# /sandcastle-dispatch-wave reads this via `gh auth token` automatically when
# gh CLI is authenticated; set it here only as an override (e.g. service
# account token, Linux without gh CLI).
GH_TOKEN=
